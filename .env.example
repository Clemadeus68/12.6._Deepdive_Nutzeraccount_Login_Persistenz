# Neon-PostgreSQL-Verbindung (Connection String aus dem Neon-Dashboard)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Geheimer Schlüssel zum Signieren der Session-Cookies (JWT).
# Sicheren Wert erzeugen z. B. mit: openssl rand -base64 32
SESSION_SECRET="bitte-einen-langen-zufaelligen-wert-eintragen"

# E-Mail-Versand für "Passwort vergessen" (optional, via https://resend.com).
# Ohne RESEND_API_KEY wird der Reset-Link nur ins Server-Log geschrieben.
RESEND_API_KEY=""
RESET_FROM_EMAIL="Alchimedus Navigator <onboarding@resend.dev>"
